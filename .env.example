# Contact form email delivery (Nodemailer over SMTP).
# Copy to .env.local and fill in. Until these are set, the contact form
# accepts submissions and logs them server-side (demo mode) without sending.

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Where enquiries are delivered (defaults to info@aillegent.com if unset)
CONTACT_TO=info@aillegent.com
